---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategoryLessons from '../../components/CategoryLessons.tsx';

export function getStaticPaths() {
  return [
    { params: { category: 'toddlers' } },
    { params: { category: 'math' } },
    { params: { category: 'science' } },
    { params: { category: 'coding' } },
    { params: { category: 'language' } },
    { params: { category: 'logic' } },
    { params: { category: 'art' } },
  ];
}

const { category } = Astro.params;
---

<BaseLayout title={`Belajar ${category}`} description="Modul dan materi pelajaran interaktif EzEdu">
  <CategoryLessons categorySlug={category} client:load />
</BaseLayout>

<style is:global>
  .category-lessons-view {
    min-height: 100vh;
    background: var(--color-bg);
    padding-bottom: var(--space-3xl);
  }

  .lessons-loading, .lessons-error {
    min-height: 100vh;
    flex-direction: column;
    gap: var(--space-md);
    padding: var(--space-3xl);
  }

  /* Category Header */
  .cat-header {
    background: linear-gradient(135deg, rgba(15, 23, 42, 0.95), var(--cat-theme-color, #6366f1));
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-xl) var(--space-lg);
  }

  .cat-header-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .back-link {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    font-weight: 600;
  }

  .back-link:hover {
    color: var(--color-text);
  }

  .cat-header-content {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
  }

  .cat-header-icon {
    font-size: 3.5rem;
    width: 5.5rem;
    height: 5.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-xl);
    backdrop-filter: blur(8px);
  }

  .cat-header-title {
    font-size: 2.2rem;
    color: white;
  }

  .cat-header-desc {
    color: rgba(255, 255, 255, 0.8);
    font-size: 1rem;
    margin-top: var(--space-xs);
  }

  /* Level Sections */
  .cat-levels-container {
    margin-top: var(--space-2xl);
  }

  .level-section {
    margin-bottom: var(--space-2xl);
  }

  .level-badge-header {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .level-pill {
    background: var(--gradient-primary);
    color: white;
    font-family: var(--font-heading);
    font-weight: 700;
    padding: var(--space-xs) var(--space-lg);
    border-radius: var(--radius-full);
    font-size: 1.1rem;
    box-shadow: var(--shadow-sm);
  }

  .level-line {
    flex: 1;
    height: 2px;
    background: var(--color-border);
  }

  .lesson-cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-lg);
  }

  .lesson-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    transition: all var(--transition-base);
  }

  .lesson-completed {
    border-color: var(--color-accent);
    background: rgba(16, 185, 129, 0.05);
  }

  .lesson-card-header {
    display: flex;
    gap: var(--space-xs);
  }

  .lesson-card-title {
    font-size: 1.25rem;
  }

  .lesson-card-desc {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-top: var(--space-xs);
  }

  .completed-info {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
  }

  .completed-badge {
    color: var(--color-accent-light);
    font-size: 0.9rem;
    font-weight: 600;
  }

  .empty-level-card {
    padding: var(--space-lg);
    text-align: center;
    border-style: dashed;
    opacity: 0.6;
  }
</style>
