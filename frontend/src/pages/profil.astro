---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProfileSelector from '../components/ProfileSelector.tsx';
---

<BaseLayout title="Pilih Profil" description="Pilih profil anak untuk mulai belajar">
  <div class="profile-page">
    <div class="profile-container animate-fade-in">
      <a href="/" class="auth-logo" id="profile-logo">
        <span class="logo-icon">🎓</span>
        <span class="logo-text">Ez<span class="text-gradient">Edu</span></span>
      </a>
      <ProfileSelector client:load />
    </div>
  </div>
</BaseLayout>

<style>
  .profile-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-xl);
    background: var(--gradient-hero);
  }

  .profile-container {
    width: 100%;
    max-width: 760px;
    text-align: center;
  }

  .auth-logo {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-text);
    text-decoration: none;
    margin-bottom: var(--space-xl);
    transition: transform var(--transition-fast);
  }

  .auth-logo:hover {
    transform: scale(1.04);
  }

  .logo-icon { font-size: 2.25rem; }
</style>

<style is:global>
  /* Header & Parent PIN Control Bar */
  .profile-header-area {
    margin-bottom: var(--space-2xl);
  }

  .profile-title {
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--color-text);
    margin-bottom: var(--space-sm);
  }

  .parent-pin-bar {
    display: flex;
    justify-content: center;
    margin-top: var(--space-xs);
  }

  .parent-pin-btn {
    background: rgba(30, 41, 59, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(99, 102, 241, 0.3);
    border-radius: var(--radius-full);
    padding: var(--space-xs) var(--space-lg);
    color: var(--color-primary-light);
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 700;
    cursor: pointer;
    transition: all var(--transition-fast);
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.25);
  }

  .parent-pin-btn:hover {
    background: rgba(99, 102, 241, 0.2);
    border-color: var(--color-primary);
    color: #ffffff;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(99, 102, 241, 0.3);
  }

  .pin-active {
    border-color: rgba(16, 185, 129, 0.4);
    color: #34d399;
  }
  .pin-active:hover {
    border-color: #10b981;
    background: rgba(16, 185, 129, 0.15);
    color: #ffffff;
  }

  .pin-icon {
    font-size: 1rem;
  }

  /* Profile Grid */
  .profile-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: var(--space-xl);
    justify-items: center;
  }

  .profile-card-wrapper {
    position: relative;
    width: 100%;
    max-width: 190px;
  }

  /* Overlay Action Buttons on Profile Cards */
  .profile-card-actions {
    position: absolute;
    top: 10px;
    right: 10px;
    display: flex;
    gap: 6px;
    z-index: 10;
  }

  .pca-btn {
    width: 28px;
    height: 28px;
    border-radius: var(--radius-full);
    background: rgba(15, 23, 42, 0.85);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: #ffffff;
    font-size: 11px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(4px);
    transition: all var(--transition-fast);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
  }

  .pca-edit:hover {
    background: #6366f1;
    border-color: #8b5cf6;
    transform: scale(1.15);
  }

  .pca-delete:hover {
    background: #ef4444;
    border-color: #f87171;
    transform: scale(1.15);
  }

  /* Profile Card */
  .profile-card {
    background: rgba(30, 41, 59, 0.7);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 2px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-2xl);
    padding: var(--space-xl) var(--space-md);
    cursor: pointer;
    transition: all var(--transition-base);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    width: 100%;
    font-family: var(--font-body);
    color: var(--color-text);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.2);
  }

  .profile-card:hover {
    border-color: var(--color-primary);
    box-shadow: 0 12px 35px rgba(99, 102, 241, 0.3);
    transform: translateY(-8px) scale(1.02);
  }

  .profile-avatar {
    font-size: 3.25rem;
    width: 5.5rem;
    height: 5.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.15), rgba(168, 85, 247, 0.15));
    border: 2px solid rgba(99, 102, 241, 0.3);
    border-radius: var(--radius-full);
    box-shadow: 0 0 15px rgba(99, 102, 241, 0.15);
    transition: transform var(--transition-fast);
  }

  .profile-card:hover .profile-avatar {
    transform: scale(1.08);
    border-color: var(--color-primary-light);
  }

  .profile-name {
    font-weight: 800;
    font-size: 1.15rem;
    color: var(--color-text);
  }

  .profile-stats {
    display: flex;
    gap: var(--space-sm);
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-text-muted);
  }

  .profile-streak {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-secondary);
  }

  /* Tambah Profil Card */
  .profile-add {
    border-style: dashed;
    border-color: rgba(255, 255, 255, 0.2);
    background: rgba(30, 41, 59, 0.3);
    opacity: 0.8;
  }

  .profile-add:hover {
    opacity: 1;
    border-color: var(--color-primary);
    background: rgba(99, 102, 241, 0.08);
  }

  .add-avatar {
    font-size: 2.5rem;
    color: var(--color-primary-light);
    background: rgba(99, 102, 241, 0.1);
    border: 2px dashed rgba(99, 102, 241, 0.3);
  }

  .profile-loading {
    flex-direction: column;
    gap: var(--space-md);
    padding: var(--space-3xl);
    color: var(--color-text-muted);
  }

  .loading-spinner {
    width: 44px;
    height: 44px;
    border: 3px solid var(--color-border);
    border-top: 3px solid var(--color-primary);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* Modal Dialog */
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(15, 23, 42, 0.8);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 200;
    padding: var(--space-lg);
  }

  .modal-content {
    background: var(--color-bg-card);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--radius-2xl);
    padding: var(--space-2xl);
    max-width: 440px;
    width: 100%;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.4);
  }

  .modal-content h3 {
    font-size: 1.4rem;
    font-weight: 800;
    margin-bottom: var(--space-xl);
    text-align: center;
    color: var(--color-text);
  }

  .modal-actions {
    display: flex;
    gap: var(--space-md);
    margin-top: var(--space-xl);
  }

  .modal-actions .btn {
    flex: 1;
  }

  /* Avatar Picker */
  .avatar-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-sm);
  }

  .avatar-option {
    font-size: 2rem;
    width: 3.5rem;
    height: 3.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg);
    border: 2px solid var(--color-border);
    border-radius: var(--radius-lg);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .avatar-option:hover {
    border-color: var(--color-primary-light);
    transform: scale(1.12);
  }

  .avatar-selected {
    border-color: var(--color-primary);
    background: rgba(99, 102, 241, 0.2);
    box-shadow: 0 0 15px rgba(99, 102, 241, 0.35);
  }

  /* PIN Modal Dialog */
  .pin-modal-content {
    max-width: 380px;
    text-align: center;
  }

  .pin-modal-subtitle {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-xl);
    line-height: 1.5;
  }

  .pin-inputs-row {
    display: flex;
    justify-content: center;
    gap: var(--space-md);
  }

  .pin-digit-box {
    width: 3.75rem;
    height: 4.25rem;
    font-size: 2.25rem;
    text-align: center;
    font-family: var(--font-heading);
    font-weight: 800;
    background: rgba(15, 23, 42, 0.9);
    border: 2px solid rgba(99, 102, 241, 0.35);
    border-radius: var(--radius-xl);
    color: var(--color-primary-light);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
    transition: all var(--transition-fast);
  }

  .pin-digit-box:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 20px rgba(99, 102, 241, 0.5);
    transform: scale(1.08);
  }

  /* Custom Toast Notification */
  .custom-toast {
    position: fixed;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(15, 23, 42, 0.95);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(16, 185, 129, 0.5);
    box-shadow: 0 10px 35px rgba(0, 0, 0, 0.5);
    border-radius: var(--radius-full);
    padding: var(--space-md) var(--space-2xl);
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    color: #ffffff;
    font-weight: 700;
    font-size: 0.95rem;
    z-index: 300;
  }

  .toast-icon {
    font-size: 1.25rem;
  }

  /* Delete Confirmation Modal */
  .delete-warning-icon {
    font-size: 3rem;
    margin-bottom: var(--space-xs);
  }

  .btn-danger {
    background: linear-gradient(135deg, #ef4444, #dc2626);
    color: white;
    border: none;
    font-family: var(--font-body);
    font-weight: 700;
    border-radius: var(--radius-md);
    padding: var(--space-sm) var(--space-lg);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .btn-danger:hover {
    background: linear-gradient(135deg, #dc2626, #b91c1c);
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(239, 68, 68, 0.4);
  }
</style>
